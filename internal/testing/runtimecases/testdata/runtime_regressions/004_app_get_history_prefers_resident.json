{
  "id": "app_get_history_prefers_persisted",
  "title": "get history prefers persisted history over resident stale history",
  "category": "state_confusion",
  "layers": ["application"],
  "application": {
    "session_id": "session-history-resident",
    "persisted_history": [
      {"role": "user", "content": "persisted history"}
    ],
    "resident_history": [
      {"role": "user", "content": "resident history"}
    ],
    "action": {
      "kind": "get_history"
    },
    "expect": {
      "history": {
        "count": 1,
        "last_content": "persisted history"
      }
    }
  }
}
